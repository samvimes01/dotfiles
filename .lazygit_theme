_terminal_bg_is_light() {
  # Need a real tty for the round-trip; skip for non-interactive shells
  [[ -t 0 && -t 1 ]] || return 1

  local response= char
  print -n $'\e]11;?\e\\'
  # Read the reply one byte at a time, stopping at either OSC terminator:
  # ST (ESC \) — used by Ghostty/tmux — or BEL — used by macOS Terminal.app.
  # A hard -d delimiter here would block forever on the terminator it doesn't
  # expect; the per-byte -t 1 timeout guarantees we never hang if a terminal
  # replies oddly or not at all (cold terminals may be slow on the first byte).
  while IFS= read -rs -t 1 -k 1 char 2>/dev/null; do
    [[ "$char" == $'\a' ]] && break            # BEL terminator
    response+="$char"
    [[ "$response" == *$'\e\\' ]] && break      # ST terminator
  done

  # Response: \e]11;rgb:RRRR/GGGG/BBBB
  if [[ "$response" =~ 'rgb:([0-9a-fA-F]+)/([0-9a-fA-F]+)/([0-9a-fA-F]+)' ]]; then
    # Take the high byte of each channel (handles both rgb:RR/GG/BB and rgb:RRRR/GGGG/BBBB)
    local r=$((16#${match[1]:0:2}))
    local g=$((16#${match[2]:0:2}))
    local b=$((16#${match[3]:0:2}))
    # Rec. 601 luma; >128 = light
    (( (r*299 + g*587 + b*114) / 1000 > 128 ))
    return $?
  fi
  return 1
}

if [[ -z "$_TERM_BG_LIGHT_CACHED" ]]; then
  _terminal_bg_is_light && export _TERM_BG_LIGHT_CACHED=1 || export _TERM_BG_LIGHT_CACHED=0
fi
[[ "$_TERM_BG_LIGHT_CACHED" == 1 ]] && export DELTA_FEATURES="+zed-light"
