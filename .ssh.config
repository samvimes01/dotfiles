Host gitlab.intersog.com
	PreferredAuthentications publickey
	IdentityFile ~/.ssh/id_ed25519_intersog

Host github.com-rham
	HostName github.com
	User git
	IdentityFile ~/.ssh/id_rham
	IdentitiesOnly yes
  UseKeychain yes

Host famelli
	HostName famelli.ftp.tools
	User famelli
	PreferredAuthentications publickey
	IdentityFile ~/.ssh/id_famelli
	IdentitiesOnly yes
	WarnWeakCrypto no-pq-kex
	SetEnv TERM=xterm-256color

Host bitbucket.org
	PreferredAuthentications publickey
	HostName bitbucket.org
	User git
	IdentityFile ~/.ssh/id_bids
	IdentitiesOnly yes
  UseKeychain yes
  WarnWeakCrypto no-pq-kex

Host dsp_t
	HostName 204.62.12.53
	Port 65123
	User oleksandr
	IdentityFile ~/.ssh/id_bids_servers
	IdentitiesOnly yes
  SetEnv TERM=xterm-256color

Host dsp_ss
	HostName 162.247.154.42
	Port 65123
	User oleksandr
	IdentityFile ~/.ssh/id_bids_servers
	IdentitiesOnly yes
	IgnoreUnknown WarnWeakCrypto
	SetEnv TERM=xterm-256color

Host dsp_wls1
	HostName 88.214.206.200
	Port 65123
	User oleksandr
	IdentityFile ~/.ssh/id_bids_servers
	IdentitiesOnly yes
	IgnoreUnknown WarnWeakCrypto
	SetEnv TERM=xterm-256color


Host github.com
	HostName github.com
	User git
	IdentityFile ~/.ssh/id_rsa
	IdentitiesOnly yes

Host *
 IdentityFile ~/.ssh/id_rsa
