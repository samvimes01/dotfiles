[core]
	excludesfile = /Users/alex/.gitignore_global
	pager = delta
[user]
	name = Oleksandr Korneiko
	email = oleksandr.korneiko@gmail.com
[includeIf "gitdir:~/workspace/archive/simplex/"]
	path = ~/.gitconfig_flex
[includeIf "gitdir:~/workspace/bids/"]
	path = ~/.gitconfig_bids
[pull]
	rebase = true
[init]
	defaultBranch = main
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[commit]
	gpgsign = true
[gpg]
	program = /usr/local/bin/gpg

[interactive]
	diffFilter = delta --color-only --features=interactive

[delta]
	features = decorations
	side-by-side = true
	# line-numbers = true

[delta "interactive"]
	keep-plus-minus-markers = false

[delta "decorations"]
	commit-decoration-style = blue ol
	commit-style = raw
	file-style = omit
	hunk-header-decoration-style = blue box
	hunk-header-file-style = red
	hunk-header-line-number-style = "#067a00"
	# hunk-header-style = file line-number syntax
	hunk-header-style = file
[alias]
	wtl = "!f() { git worktree list; }; f"
	wta = "!f() { \
		base=$(basename $(git rev-parse --show-toplevel)); \
		target=\"/Users/alex/workspace/_gitwork/$base/$1\"; \
		mkdir -p \"$target\" && \
		git worktree add -b \"$1\" \"$target\" && \
		[ -f \".env\" ] && cp .env \"$target/.env\"; \
		cd \"$target\" && npm ci; \
	}; f \"$@\""
	wtr = "!f() { \
		base=$(basename $(git rev-parse --show-toplevel)); \
		target=\"/Users/alex/workspace/_gitwork/$base/$1\"; \
		git worktree remove \"$target\"; \
	}; f \"$@\""
